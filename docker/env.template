# U Docker Composeu: u vrijednosti % napiši kao %%, a $ kao $$
# Primjer ako lozinka završava na "#%": POSTGRES_PASSWORD="...\"#%%"

POSTGRES_USER=startline
POSTGRES_PASSWORD=postavi_jaku_lozinku
POSTGRES_DB=startline

# Android šalje istu vrijednost u headeru: X-API-Key
API_KEY=postavi_dugi_tajni_kljuc

